### AL ###
# Ignore all generated report artifacts in software/output,
# but keep the directory itself (and the .gitkeep placeholder) tracked.
# Output directory (ignore all generated test results)
output_dir/
!/output_dir/
# Keep folder structure (optional)
!output_dir/.gitkeep

# Python bytecode cache (all levels)
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
# Ignore Python bytecode caches in the software tree
/__pycache__/
/.pytest_cache/
/tests_lib/__pycache__/
/*/*/*.log
/*/*.log
/*.log
/log/*
/prj/*
!/prj
*.jou  
*.log
*.str
.Xil
.mr.developer.cfg
.project
*.pydevproject
.settings
*DS_Store
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml
